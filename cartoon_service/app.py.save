# app.py
from flask import Flask, request, send_file
from PIL import Image, ImageOps
import io
import os

app = Flask(__name__)

def make_cartoon(image_bytes, strength=2):
    """Convert image to cartoon-like effect with adjustable strength (2-10)"""
    img = Image.open(io.BytesIO(image_bytes))
    img = ImageOps.grayscale(img)
    
    # Posterize based on strength: lower levels = more posterization
    levels = max(2, min(10, strength))
    img = img.point(lambda x: (x // (256 // levels)) * (256 // levels))
    
    output = io.BytesIO()
    img.save(output, format='PNG')
    output.seek(0)
    return output

